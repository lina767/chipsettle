---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ChipSettle — the navigator for semiconductor design settlement instruments in Europe. Fiscal instruments, funding programs, and legal requirements in one place.' } = Astro.props;

const nav = [
  { href: '/wizard', label: 'Wizard' },
  { href: '/compare', label: 'Compare' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · ChipSettle</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-slate-200 bg-white no-print sticky top-0 z-40">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 font-semibold text-slate-900">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded bg-blue-900 text-white text-xs font-bold tracking-tight">CS</span>
          <span class="tracking-tight">ChipSettle</span>
        </a>
        <nav class="flex items-center gap-1 sm:gap-2 text-sm overflow-x-auto">
          {nav.map((item) => (
            <a
              href={item.href}
              class={`px-2 sm:px-3 py-1.5 rounded whitespace-nowrap hover:bg-slate-100 ${
                currentPath.startsWith(item.href) ? 'text-blue-900 font-medium' : 'text-slate-600'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8 space-y-4">
        <p class="text-xs leading-relaxed text-slate-500 max-w-4xl">
          <strong class="text-slate-600">Disclaimer:</strong> This tool provides structured policy
          information for orientation purposes. It does not constitute legal, tax, or investment
          advice. All parameters are verified as of the dates shown and may have changed. Consult
          a qualified advisor before making decisions.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-500 no-print">
          <a href="/methodology" class="hover:text-slate-700">Methodology &amp; sources</a>
          <a href="/changelog" class="hover:text-slate-700">Changelog</a>
          <a href="/about" class="hover:text-slate-700">About this project</a>
          <span>Database last updated: 3 Jul 2026</span>
        </div>
      </div>
    </footer>
  </body>
</html>
