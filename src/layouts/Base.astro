---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ChipSettle — the navigator for semiconductor design settlement instruments in Europe. Fiscal instruments, funding programs, and legal requirements in one place.' } = Astro.props;

const nav = [
  { href: '/wizard', label: 'Wizard' },
  { href: '/compare', label: 'Compare' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const pageTitle = isHome
  ? 'ChipSettle — Every European chip-design incentive. One filtered view.'
  : `${title} · ChipSettle`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL('/og-image.png', Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ChipSettle" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ChipSettle — every European chip-design incentive, one filtered view." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b hairline bg-white/85 backdrop-blur no-print sticky top-0 z-40">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2.5 text-slate-900">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded bg-blue-900 text-white mono text-[11px] font-bold">CS</span>
          <span class="flex flex-col leading-none">
            <span class="font-[650] tracking-tight text-[15px]">ChipSettle</span>
            <span class="label-mono text-slate-400 mt-0.5">EU chip-design settlement</span>
          </span>
        </a>
        <nav class="flex items-center gap-0.5 sm:gap-1 text-[13px] overflow-x-auto">
          {nav.map((item) => (
            <a
              href={item.href}
              class={`px-2 sm:px-3 py-1.5 rounded whitespace-nowrap hover:bg-slate-100 transition-colors ${
                currentPath.startsWith(item.href)
                  ? 'text-blue-900 font-semibold'
                  : 'text-slate-500'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t hairline bg-white mt-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8 space-y-4">
        <p class="text-xs leading-relaxed text-slate-500 max-w-4xl">
          <strong class="text-slate-600">⚠ Disclaimer.</strong> Structured policy information for
          orientation only — not legal, tax, or investment advice. Parameters are verified as of the
          dates shown and may have changed. Consult a qualified advisor before deciding.
        </p>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-slate-500 no-print">
          <a href="/methodology" class="hover:text-slate-800">Methodology</a>
          <a href="/changelog" class="hover:text-slate-800">Changelog</a>
          <a href="/about" class="hover:text-slate-800">About</a>
          <span class="label-mono text-slate-400">DB updated 2026-07-03</span>
        </div>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
