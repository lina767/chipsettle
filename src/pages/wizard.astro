---
import Base from '../layouts/Base.astro';
import Wizard from '../components/Wizard';
---

<Base title="Company profile wizard">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10">
    <div class="mx-auto max-w-2xl mb-8">
      <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Your company profile</h1>
      <p class="mt-2 text-sm text-slate-500">
        Three steps, under three minutes. Nothing is stored — your profile lives in the results
        URL, so you can share or bookmark it.
      </p>
    </div>
    <Wizard client:load />
  </div>
</Base>
