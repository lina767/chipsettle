---
import Base from '../layouts/Base.astro';
import Wizard from '../components/Wizard';
---

<Base title="Company profile wizard">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10">
    <div class="mx-auto max-w-2xl mb-8">
      <p class="eyebrow mb-2">4 steps · ~1 min</p>
      <h1 class="text-2xl text-slate-900">Your company profile</h1>
      <p class="mt-2 text-sm text-slate-500">Nothing stored — lives in the results URL, shareable/bookmarkable.</p>
    </div>
    <Wizard client:load />
  </div>
</Base>
