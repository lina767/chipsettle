---
import Base from '../layouts/Base.astro';
import { instruments } from '../data/instruments';
import { countries, seededCountrySlugs, getCountry } from '../data/countries';
import { formatDate } from '../lib/labels';

const activeCount = instruments.filter((i) => i.status !== 'expired').length;
const countryCount = seededCountrySlugs.length;

// Timeline: recent and upcoming changes across the database (datedness as design element)
const timeline = [
  { date: '2027-01-01', label: 'NL expat ruling: tax-free share 30% → 27%', country: 'netherlands', upcoming: true },
  { date: '2026-01-01', label: 'DE Forschungszulage: base cap → €12M + 20% overhead flat rate', country: 'germany', upcoming: false },
  { date: '2026-01-01', label: 'NL WBSO: first bracket → €391,020 (rates 36% / 16%)', country: 'netherlands', upcoming: false },
  { date: '2025-02-28', label: 'FR JEI: R&D-spend threshold raised 15% → 20%', country: 'france', upcoming: false },
  { date: '2025-02-15', label: 'FR CIR: base narrowed (operating-cost rate 43% → 40%)', country: 'france', upcoming: false },
  { date: '2025-01-01', label: 'BE inbound-taxpayer regime: allowance 30% → 35%, cap dropped', country: 'belgium', upcoming: false },
].sort((a, b) => b.date.localeCompare(a.date));

const steps = [
  { n: '01', h: 'Describe your company', items: ['HQ, business model, size, revenue', 'Sectors + end-market industries', 'Goal: design site · R&D · IP · pilot lines'] },
  { n: '02', h: 'Get your dashboard', items: ['Deterministic engine, not a chatbot', 'Filtered to your profile', 'Eligibility + relevance per instrument'] },
  { n: '03', h: 'Compare & act', items: ['Side-by-side across countries', 'Support estimate + action roadmap', 'Export PDF for your board'] },
];
---

<Base title="Home" description="ChipSettle helps semiconductor companies identify which fiscal instruments, funding programs, and legal requirements apply when establishing a design site in Europe.">
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pt-16 pb-12">
    <div class="max-w-3xl">
      <p class="eyebrow mb-4">Semiconductor design settlement navigator</p>
      <h1 class="text-4xl sm:text-6xl text-slate-900 leading-[1.02]">
        Every European chip-design incentive. One filtered view.
      </h1>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-2xl">
        Fiscal instruments, funding, visa pathways and legal steps are scattered across tax codes,
        EU regulations and program sites that don't reference each other. ChipSettle assembles them
        — <strong>verified, dated, source-linked</strong> — and filters them to your profile.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/wizard" class="rounded-lg bg-blue-900 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-800 transition-colors">
          Start the 3-min wizard →
        </a>
        <a href="/compare" class="rounded-lg border hairline bg-white px-6 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
          Compare countries
        </a>
      </div>
      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 mono text-xs text-slate-500">
        <span><span class="text-blue-900 font-semibold">{activeCount}</span> verified instruments</span>
        <span><span class="text-blue-900 font-semibold">{countryCount}</span> countries + EU</span>
        <span>legal basis + source on every entry</span>
        <span>no AI-generated answers</span>
      </div>
    </div>
  </section>

  <section class="border-y hairline bg-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((s) => (
        <div>
          <div class="flex items-baseline gap-2 mb-3">
            <span class="mono text-sm text-blue-900 font-semibold">{s.n}</span>
            <h2 class="text-base text-slate-900">{s.h}</h2>
          </div>
          <ul class="space-y-1.5">
            {s.items.map((it) => (
              <li class="flex gap-2 text-sm text-slate-600">
                <span class="text-blue-900/50" aria-hidden="true">→</span>
                {it}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12 grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-10">
    <div>
      <h2 class="text-lg text-slate-900 mb-4 tick">Coverage</h2>
      <ul class="divide-y hairline border-y hairline">
        {countries.filter((c) => c.slug !== 'eu').map((c) => {
          const seeded = seededCountrySlugs.includes(c.slug);
          return (
            <li class="flex items-center justify-between py-2.5">
              <a href={`/country/${c.slug}`} class="text-sm text-slate-800 hover:text-blue-900 font-medium">
                {c.flag_emoji} {c.name}
              </a>
              <span class={`label-mono ${seeded ? 'text-emerald-700' : 'text-slate-400'}`}>
                {seeded ? '✓ verified' : 'planned'}
              </span>
            </li>
          );
        })}
        <li class="flex items-center justify-between py-2.5">
          <a href="/country/eu" class="text-sm text-slate-800 hover:text-blue-900 font-medium">🇪🇺 EU level</a>
          <span class="label-mono text-emerald-700">✓ verified</span>
        </li>
      </ul>
    </div>
    <div>
      <h2 class="text-lg text-slate-900 mb-4 tick">Recent &amp; upcoming changes</h2>
      <ol class="space-y-2.5">
        {timeline.map((t) => {
          const c = getCountry(t.country);
          return (
            <li class="flex gap-3 text-sm items-baseline">
              <span class={`mono shrink-0 w-[92px] text-[11px] ${t.upcoming ? 'text-amber-700 font-semibold' : 'text-slate-400'}`}>
                {formatDate(t.date)}
              </span>
              <span class="text-slate-700 leading-snug">
                <span class="mr-1">{c?.flag_emoji}</span>{t.label}
                {t.upcoming && <span class="ml-1.5 label-mono text-amber-700">upcoming</span>}
              </span>
            </li>
          );
        })}
      </ol>
      <a href="/changelog" class="mt-4 inline-block text-sm text-blue-800 hover:underline">Full changelog →</a>
    </div>
  </section>
</Base>
