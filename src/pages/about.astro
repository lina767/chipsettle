---
import Base from '../layouts/Base.astro';

const gap = [
  'No single point assembles fiscal instruments, funding, visa pathways and legal steps across EU member states.',
  'The information exists — but it is scattered across national tax codes, EU regulations and program sites that don\'t cross-reference.',
  'A CFO weighing DE research allowance vs. NL innovation box + expat ruling, plus how Chips JU and Pillar Two interact, must rebuild the picture from a dozen primary sources.',
];
const approach = [
  ['Structured navigator, not a chatbot', 'A deterministic engine filters a verified database — no LLM-generated answers.'],
  ['Traceable by design', 'Every data point cites a legal basis + official source, with a verification date shown.'],
  ['Honest about time', 'Staleness warnings after 6 months; recent changes and proposed instruments flagged.'],
];
const scope = [
  'Use case: additional design site in Europe',
  'Seeded: 🇩🇪 🇳🇱 🇧🇪 🇫🇷 🇪🇸 + 🇪🇺 EU level',
  'No accounts · no AI layer · no automated ingestion — every entry manually verified',
];
const future = ['Email alerts on instrument changes', 'Embeddable widget for development agencies', 'API for site-selection tools', 'Multilingual (EN/DE/FR/NL)'];
---

<Base title="About" description="The policy gap ChipSettle addresses, and the project context behind it.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 space-y-10">
    <header>
      <p class="eyebrow mb-3">About</p>
      <h1 class="text-3xl text-slate-900">Why ChipSettle exists</h1>
    </header>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">The policy gap</h2>
      <ul class="space-y-2">
        {gap.map((g) => (
          <li class="flex gap-2.5 text-sm text-slate-600">
            <span class="text-blue-900/50 mt-0.5" aria-hidden="true">→</span>{g}
          </li>
        ))}
      </ul>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">The approach</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {approach.map(([h, d]) => (
          <div class="rounded-lg border hairline bg-white p-4">
            <dt class="text-sm font-semibold text-slate-900 mb-1">{h}</dt>
            <dd class="text-xs text-slate-600 leading-relaxed">{d}</dd>
          </div>
        ))}
      </dl>
      <p class="text-sm text-slate-500">
        See <a href="/methodology" class="text-blue-800 underline">methodology</a> for how the engine
        filters, ranks and verifies.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Scope of v1</h2>
      <ul class="space-y-1.5">
        {scope.map((s) => (
          <li class="flex gap-2.5 text-sm text-slate-600">
            <span class="text-emerald-600 mt-0.5" aria-hidden="true">✓</span>{s}
          </li>
        ))}
      </ul>
      <p class="label-mono text-slate-400 pt-1">Planned next</p>
      <div class="flex flex-wrap gap-1.5">
        {future.map((f) => (
          <span class="rounded bg-slate-50 border hairline px-2 py-0.5 text-[11px] text-slate-600">{f}</span>
        ))}
      </div>
    </section>

    <p class="text-xs text-slate-400 border-t hairline pt-4">
      ⚠ Orientation only — not legal, tax, or investment advice.
    </p>
  </div>
</Base>
