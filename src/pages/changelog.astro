---
import Base from '../layouts/Base.astro';
import { instruments } from '../data/instruments';
import { getCountry } from '../data/countries';
import { formatDate } from '../lib/labels';

// Flatten all changelog entries across instruments into one global timeline.
interface Entry {
  date: string;
  change: string;
  source: string;
  instrumentName: string;
  instrumentSlug: string;
  countrySlug: string;
}

const entries: Entry[] = instruments
  .flatMap((i) =>
    i.changelog.map((c) => ({
      ...c,
      instrumentName: i.name,
      instrumentSlug: i.slug,
      countrySlug: i.country,
    })),
  )
  .sort((a, b) => b.date.localeCompare(a.date));

// Upcoming dated changes (scheduled parameter changes).
const upcoming = [
  { date: '2027-01-01', label: 'NL expat ruling: tax-free share drops from 30% to 27%', slug: 'nl-expat-ruling', country: 'netherlands' },
]
  .filter((u) => u.date >= '2026-07-03')
  .sort((a, b) => a.date.localeCompare(b.date));

const grouped = entries.reduce<Record<string, Entry[]>>((acc, e) => {
  const year = e.date.slice(0, 4);
  (acc[year] ??= []).push(e);
  return acc;
}, {});
const years = Object.keys(grouped).sort((a, b) => b.localeCompare(a));
---

<Base title="Changelog" description="A global timeline of changes to every instrument in the ChipSettle database — the tool is honest about its temporal limits.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 space-y-10">
    <header>
      <p class="eyebrow mb-3">Changelog</p>
      <h1 class="text-3xl text-slate-900">Every recorded change</h1>
      <p class="mt-3 text-slate-600 leading-relaxed text-sm">
        Global timeline across the database, plus scheduled changes. Each instrument also carries
        its own changelog on its detail page.
      </p>
    </header>

    {upcoming.length > 0 && (
      <section>
        <h2 class="text-lg text-slate-900 mb-3 tick">Upcoming</h2>
        <ol class="space-y-3 border-l-2 border-amber-300 pl-4">
          {upcoming.map((u) => (
            <li class="relative">
              <span class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-amber-500"></span>
              <p class="mono text-xs font-medium text-amber-700">{formatDate(u.date)}</p>
              <p class="text-sm text-slate-800">
                <span class="mr-1">{getCountry(u.country)?.flag_emoji}</span>
                <a href={`/instrument/${u.slug}`} class="hover:underline">{u.label}</a>
              </p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {years.map((year) => (
      <section>
        <h2 class="text-lg text-slate-900 mb-3 tick mono">{year}</h2>
        <ol class="space-y-4 border-l-2 border-slate-200 pl-4">
          {grouped[year].map((e) => (
            <li class="relative">
              <span class="absolute -left-[21px] top-1.5 w-2.5 h-2.5 rounded-full bg-blue-800"></span>
              <p class="mono text-xs font-medium text-slate-500">{formatDate(e.date)}</p>
              <p class="text-sm text-slate-800">
                <span class="mr-1">{getCountry(e.countrySlug)?.flag_emoji}</span>
                <a href={`/instrument/${e.instrumentSlug}`} class="font-medium text-slate-900 hover:text-blue-900 hover:underline">{e.instrumentName}</a>:
                {' '}{e.change}
              </p>
              <p class="text-xs text-slate-400">Source: {e.source}</p>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</Base>
