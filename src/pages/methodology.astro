---
import Base from '../layouts/Base.astro';
import { instruments } from '../data/instruments';
import { countries, seededCountrySlugs } from '../data/countries';

const total = instruments.length;
const needVerify = instruments.filter((i) => i.needs_verification);
const proposed = instruments.filter((i) => i.status === 'proposed');
const notSeeded = countries.filter((c) => c.slug !== 'eu' && !seededCountrySlugs.includes(c.slug));

const filters = [
  ['Status', 'active, expiring or proposed only'],
  ['Country', 'your targets + all EU-level instruments'],
  ['HQ', 'only specific-HQ rules hard-filter; EU-establishment downgrades, not excludes'],
  ['Model · size · sector · goal', 'removed if eligibility explicitly excludes you'],
];
const scoring = [
  ['Rule-based > discretionary', 'a self-assessed entitlement beats a call you might lose'],
  ['Active > proposed', 'enacted outranks legislative proposals'],
  ['Fiscal & practical impact', 'weighted for your selected goal'],
  ['Goal alignment', 'core-purpose match ranks above secondary'],
  ['SME uplift', 'where an instrument is materially more generous to SMEs'],
];
const entity = [
  ['No local presence', 'the point doesn\'t depend on where you\'re established'],
  ['Tax presence (branch)', 'a branch/permanent establishment is enough — most R&D credits, payroll & IP boxes'],
  ['Separate legal entity', 'a distinct legal person is required — most grant programs'],
];
---

<Base title="Methodology" description="How ChipSettle works: a deterministic decision engine over a verified, source-linked database — no AI-generated answers.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 space-y-10">
    <header>
      <p class="eyebrow mb-3">Methodology</p>
      <h1 class="text-3xl text-slate-900">A filter, not a chatbot</h1>
      <p class="mt-3 text-slate-600 leading-relaxed">
        Every answer comes from a verified database entry — legal basis, source link, verification
        date. Nothing is generated by a language model.
      </p>
    </header>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Decision engine</h2>
      <p class="text-sm text-slate-500">Hard filters, in order:</p>
      <ol class="space-y-1.5">
        {filters.map(([h, d], idx) => (
          <li class="flex gap-3 text-sm">
            <span class="mono text-blue-900 font-semibold shrink-0">{String(idx + 1).padStart(2, '0')}</span>
            <span class="text-slate-700"><strong class="text-slate-900">{h}</strong> — {d}</span>
          </li>
        ))}
      </ol>
      <p class="text-sm text-slate-600 leading-relaxed">
        Survivors get an eligibility status — <span class="label-mono text-emerald-700">eligible</span>,
        <span class="label-mono text-lime-700">likely</span>,
        <span class="label-mono text-amber-700">conditional</span>,
        <span class="label-mono text-slate-500">not eligible</span> — from soft signals (EU
        establishment, local substance, discretionary approval, proposed status, the €750M Pillar Two
        threshold). Each conditional card states its reason and the path to satisfy it.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Relevance scoring</h2>
      <ul class="space-y-1.5">
        {scoring.map(([h, d]) => (
          <li class="flex gap-2.5 text-sm text-slate-600">
            <span class="text-blue-900/50 mt-0.5" aria-hidden="true">→</span>
            <span><strong class="text-slate-900">{h}.</strong> {d}</span>
          </li>
        ))}
      </ul>
      <p class="text-sm text-slate-500">Absence entries and figures pending verification rank lower — but stay visible, so comparisons stay honest.</p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Local presence</h2>
      <p class="text-sm text-slate-500">A foreign firm rarely needs a full subsidiary. Each instrument records one of three levels:</p>
      <dl class="space-y-1.5">
        {entity.map(([h, d]) => (
          <div class="flex gap-2.5 text-sm">
            <dt class="label-mono text-blue-900 shrink-0 w-40 pt-0.5">{h}</dt>
            <dd class="text-slate-600">{d}</dd>
          </div>
        ))}
      </dl>
      <p class="text-sm text-slate-500">The action roadmap opens each country with a "choose your entity path" recommendation; country pages list branch and Employer-of-Record alternatives.</p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Verification &amp; datedness</h2>
      <ul class="space-y-1.5 text-sm text-slate-600">
        <li class="flex gap-2.5"><span class="text-blue-900/50" aria-hidden="true">→</span>Every entry: <span class="mono text-slate-800">last-verified</span>, source, next-review date.</li>
        <li class="flex gap-2.5"><span class="text-blue-900/50" aria-hidden="true">→</span>Verified &gt; 6 months ago shows a ⚠ staleness warning; recent changes show a ● badge.</li>
      </ul>
      <div class="rounded-lg border hairline bg-white p-4 grid grid-cols-3 gap-3 text-center">
        <div><p class="mono text-2xl text-slate-900">{total}</p><p class="label-mono text-slate-400 mt-1">instruments</p></div>
        <div><p class="mono text-2xl text-slate-900">{proposed.length}</p><p class="label-mono text-slate-400 mt-1">proposed</p></div>
        <div><p class="mono text-2xl text-slate-900">{needVerify.length}</p><p class="label-mono text-slate-400 mt-1">verify pending</p></div>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg text-slate-900 tick">Coverage &amp; maintenance</h2>
      <p class="text-sm text-slate-600">
        Seeded for {seededCountrySlugs.length} countries + EU. Selectable but not yet seeded:
        {notSeeded.map((c) => <span class="mono text-xs text-slate-500">{c.flag_emoji} {c.code}&nbsp;</span>)}
      </p>
      <p class="text-sm text-slate-500">Maintained via a CMS (Payload) — editors update parameters without code changes. No automated ingestion; every entry is verified against an official source.</p>
    </section>

    <p class="text-xs text-slate-400 border-t hairline pt-4">
      ⚠ Orientation, not advice. The engine tells you which instruments plausibly apply and where to
      read the law — not your tax position. Consult a qualified advisor before deciding.
    </p>
  </div>
</Base>
