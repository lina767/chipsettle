---
import Base from '../layouts/Base.astro';
import ResultsDashboard from '../components/ResultsDashboard';
---

<Base title="Your instrument dashboard">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10">
    <ResultsDashboard client:only="react" />
    <noscript>
      <p class="text-sm text-slate-600">
        The personalized dashboard requires JavaScript. Country pages work without it:
        <a href="/country/germany" class="underline">Germany</a>,
        <a href="/country/netherlands" class="underline">Netherlands</a>,
        <a href="/country/france" class="underline">France</a>.
      </p>
    </noscript>
  </div>
</Base>
